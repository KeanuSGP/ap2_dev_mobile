<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".lancamentos">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        >
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/logoff_barra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:name="com.example.ap2_dev_mobile.logoff_barra"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:layout="@layout/fragment_logoff_barra"
            />

        <TextView
            android:id="@+id/pagina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lançamentos"
            android:textSize="30dp"
            android:textColor="@color/main"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/logoff_barra"
            app:layout_constraintStart_toStartOf="parent"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/criar_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/adicionar"
            android:text="Criar Lançamento"
            android:backgroundTint="@color/main"
            app:cornerRadius="10dp"
            android:textSize="20sp"
            android:fontFamily="@font/rotobo_variavel"
            app:iconSize="30sp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            app:layout_constraintTop_toBottomOf="@id/pagina"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="20dp"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/filtros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/criar_btn"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            >
            <TextView
                android:id="@+id/filtros_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FILTROS"
                android:textSize="20sp"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/container_interno_filtros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/filtros_txt"
                >
                <LinearLayout
                    android:id="@+id/filtro_tipo_lancamento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:padding="10dp"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp"
                    >
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TIPO"
                            android:layout_marginRight="10dp"
                            android:textSize="18dp"
                            />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filtroReceita"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:text="receita"
                            app:cornerRadius="10dp"
                            android:textSize="20sp"
                            app:strokeColor="@color/main"
                            app:strokeWidth="2sp"
                            android:padding="0dp"
                            android:fontFamily="@font/rotobo_variavel"
                            android:textColor="@color/main"
                            android:backgroundTint="@color/white"
                            />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filtroDespesa"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:backgroundTint="@color/white"
                            android:text="despesa"
                            app:cornerRadius="10dp"
                            android:textSize="20sp"
                            android:padding="0dp"
                            android:layout_marginLeft="5dp"
                            app:strokeColor="@color/main"
                            app:strokeWidth="2sp"
                            android:textColor="@color/main"
                            android:fontFamily="@font/rotobo_variavel"
                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SITUAÇÃO"
                            android:layout_marginRight="10dp"
                            android:textSize="18dp"
                            />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filtroAberta"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:backgroundTint="@color/white"
                            app:strokeColor="@color/main"
                            app:strokeWidth="2sp"
                            android:text="aberta"
                            app:cornerRadius="10dp"
                            android:textSize="20sp"
                            android:padding="0dp"
                            android:textColor="@color/main"
                            android:fontFamily="@font/rotobo_variavel"
                            />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/filtroQuitada"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:backgroundTint="@color/white"
                            android:text="Quitado"
                            app:cornerRadius="10dp"
                            android:textSize="20sp"
                            android:padding="0dp"
                            android:layout_marginLeft="5dp"
                            app:strokeColor="@color/main"
                            app:strokeWidth="2sp"
                            android:textColor="@color/main"
                            android:fontFamily="@font/rotobo_variavel"
                            />

                    </LinearLayout>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/lancamentos_rv"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/filtros"
            app:layout_constraintBottom_toBottomOf="parent"
            android:paddingBottom="50dp"
            android:layout_marginTop="20dp"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:name="com.example.ap2_dev_mobile.navbar"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout="@layout/fragment_navbar"
        />

</androidx.constraintlayout.widget.ConstraintLayout>