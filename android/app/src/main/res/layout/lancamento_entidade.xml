<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_conta_financeira"
        android:layout_width="300dp"
        android:layout_height="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:padding="10dp"
        android:background="@color/main"
        >

        <TextView
            android:id="@+id/id_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="{ID}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:textColor="@color/white"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            app:layout_constraintTop_toBottomOf="@id/id_item"
            android:background="@color/white"
            android:layout_marginTop="5dp"

            />


        <LinearLayout
            android:id="@+id/headers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/id_item"
            android:textColor="@color/white"
            >

            <TextView
                android:id="@+id/header_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ITEM"
                app:layout_constraintTop_toBottomOf="@+id/id_item"
                app:layout_constraintStart_toStartOf="parent"
                android:textColor="@color/white"
                />

            <TextView
                android:layout_width="10dp"
                android:layout_height="30dp"
                app:layout_constraintStart_toEndOf="@id/header_item"
                app:layout_constraintTop_toBottomOf="@id/id_item"
                android:text="|"
                android:fontFamily="@font/rotobo_variavel"
                android:textFontWeight="600"
                android:textSize="18sp"
                android:gravity="center"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/header_saldo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SALDO"
                app:layout_constraintStart_toEndOf="@id/header_item"
                app:layout_constraintTop_toBottomOf="@id/id_item"
                android:textColor="@color/white"
                />

            <TextView
                android:layout_width="10dp"
                android:layout_height="30dp"
                app:layout_constraintStart_toEndOf="@id/header_item"
                app:layout_constraintTop_toBottomOf="@id/id_item"
                android:text="|"
                android:fontFamily="@font/rotobo_variavel"
                android:textFontWeight="600"
                android:textSize="18sp"
                android:gravity="center"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/header_lancamentos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LANÇAMENTOS"
                app:layout_constraintStart_toEndOf="@id/header_valor"
                app:layout_constraintTop_toBottomOf="@id/id_item"
                android:textColor="@color/white"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/valores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headers"
            android:orientation="horizontal"
            >
            <TextView
                android:id="@+id/valor_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="valorItem"
                app:layout_constraintStart_toEndOf="parent"
                android:textColor="@color/white"
                />
            <TextView
                android:layout_width="10dp"
                android:layout_height="30dp"
                app:layout_constraintStart_toEndOf="@id/valor_item"
                android:text="|"
                android:fontFamily="@font/rotobo_variavel"
                android:textFontWeight="600"
                android:textSize="18sp"
                android:gravity="center"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/valor_valor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="valorValor"
                app:layout_constraintStart_toEndOf="parent"
                android:textColor="@color/white"
                />
            <TextView
                android:layout_width="10dp"
                android:layout_height="30dp"
                app:layout_constraintStart_toEndOf="@id/valor_valor"
                android:text="|"
                android:fontFamily="@font/rotobo_variavel"
                android:textFontWeight="600"
                android:textSize="18sp"
                android:gravity="center"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/valor_vencimento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="valorVencimento"
                app:layout_constraintStart_toEndOf="parent"
                android:textColor="@color/white"
                />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="100dp"
        app:layout_constraintStart_toEndOf="@id/card_conta_financeira"
        app:layout_constraintTop_toTopOf="parent"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginLeft="20dp"
        >

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ver"
            app:tint="@color/main"
            />

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/editar_icon"
            app:tint="@color/main"
            />

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/deletar_icon"
            app:tint="@color/vermelho_despesa"
            />


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>