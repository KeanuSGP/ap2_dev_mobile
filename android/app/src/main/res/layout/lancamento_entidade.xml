<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >

    <androidx.cardview.widget.CardView
        android:id="@+id/card_view_entidade"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_conta_financeira"
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:padding="10dp"
            android:background="@color/main"
            >

            <TextView
                android:id="@+id/id_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="{ID}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:textColor="@color/white"
                />

            <LinearLayout
                android:id="@+id/divisor"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                app:layout_constraintTop_toBottomOf="@id/id_item"
                android:background="@color/white"
                android:layout_marginTop="5dp"

                />


            <LinearLayout
                android:id="@+id/valores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divisor"
                android:orientation="vertical"
                >
                <TextView
                    android:id="@+id/valor_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="valorItem"
                    app:layout_constraintStart_toEndOf="parent"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    />

                <TextView
                    android:id="@+id/valor_valor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="valorValor"
                    app:layout_constraintStart_toEndOf="parent"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    />


                <TextView
                    android:id="@+id/valor_vencimento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="valorVencimento"
                    app:layout_constraintStart_toEndOf="parent"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    />


                <TextView
                    android:id="@+id/valor_situacao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="valorSitucao"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="100dp"
        app:layout_constraintStart_toEndOf="@id/card_view_entidade"
        app:layout_constraintTop_toTopOf="parent"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginLeft="20dp"
        >

        <ImageView
            android:id="@+id/edit_btn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/editar_icon"
            app:tint="@color/main"
            />

        <ImageView
            android:id="@+id/delete_btn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/deletar_icon"
            app:tint="@color/vermelho_despesa"
            />


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>