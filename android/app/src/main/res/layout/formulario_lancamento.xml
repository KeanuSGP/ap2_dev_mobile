<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/main"
    android:padding="20dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        >
        <LinearLayout
            android:id="@+id/header_info"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:orientation="horizontal"
            android:gravity="center"
            >
            <TextView
                android:id="@+id/id_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="{id}"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="18sp"
                />

            <TextView
                android:layout_width="10dp"
                android:layout_height="40dp"
                app:layout_constraintStart_toEndOf="@id/id_item"
                android:text="|"
                android:fontFamily="@font/rotobo_variavel"
                android:textFontWeight="400"
                android:textSize="25sp"
                android:gravity="center"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/situacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="{SITUAÇÃO}"
                android:textColor="@color/white"
                android:textSize="18sp"
                />
            
        </LinearLayout>
        
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/fechar"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/valores_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/header"
        android:padding="30dp"
        >
        <LinearLayout
            android:id="@+id/item_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            >
            <TextView
                android:id="@+id/item_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ITEM"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/item_valor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="{ITEM}"
                android:textColor="@color/white"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dt_compra_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/item_container"
            android:layout_marginTop="20dp"
            >
            <TextView
                android:id="@+id/dt_compra_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATA DE COMPRA"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/dt_compra_valor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="{dd/MM/yyyy}"
                android:textColor="@color/white"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/valor_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dt_compra_container"
            android:layout_marginTop="20dp"
            >
            <TextView
                android:id="@+id/valor_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VALOR"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/valor_valor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ {0,00}"
                android:textColor="@color/white"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/vencimento_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/valor_container"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/vencimento_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VENCIMENTO"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/vencimento_valor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2026"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/categoria_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/vencimento_container"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/categoria_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATEGORIA"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/categoria_valor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alimentação"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tipo_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/categoria_container"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/tipo_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIPO"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tipo_valor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Despesa"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/descricao_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tipo_container"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/descricao_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIÇÃO"
                android:textColor="@color/white" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                >

                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="130dp"
                     android:background="@color/white"
                     android:padding="15dp"
                     >
                     <TextView
                         android:id="@+id/descricao_valor"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:text="Lorem Ipsum is simply dummy text of the printing and  typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since 1966"
                        />

                 </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/acao_btn"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:text="AÇÃO"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/valores_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cornerRadius="10dp"
        android:backgroundTint="@color/botao_formulario"
        android:textSize="20sp"
        />

</androidx.constraintlayout.widget.ConstraintLayout>