<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/main"
    android:padding="20dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        >
        <LinearLayout
            android:id="@+id/header_info"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:orientation="horizontal"
            android:gravity="center"
            >
            <TextView
                android:id="@+id/id_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="{id}"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="18sp"
                />


        </LinearLayout>

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/fechar"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/valores_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/header"
        android:padding="20dp"
        >
        <LinearLayout
            android:id="@+id/item_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            >
            <TextView
                android:id="@+id/item_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ITEM"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/item_valor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="{ITEM}"
                android:textColor="@color/white"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dt_compra_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/item_container"
            android:layout_marginTop="20dp"
            >
            <TextView
                android:id="@+id/dt_compra_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATA DE COMPRA"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/dt_compra_valor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="{dd/MM/yyyy}"
                android:textColor="@color/white"
                />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/acao_btn"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:text="AÇÃO"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/valores_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cornerRadius="10dp"
        android:backgroundTint="@color/botao_formulario"
        android:textSize="20sp"
        />

</androidx.constraintlayout.widget.ConstraintLayout>